# ── Server ──────────────────────────────────────────
PORT=3000
NODE_ENV=development          # development | production

# ── Database (PostgreSQL) ────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/studyhive
# Railway/Render will inject this automatically when you
# provision a Postgres addon. For local dev, create a DB
# and fill in the values above.

# ── JWT ─────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=another_long_random_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# ── Session (used by Passport OAuth) ────────────────
SESSION_SECRET=yet_another_long_random_secret

# ── Google OAuth ─────────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://your-app.onrender.com/api/auth/google/callback

# ── Microsoft OAuth ──────────────────────────────────
# Create at https://portal.azure.com → App registrations
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_CALLBACK_URL=https://your-app.onrender.com/api/auth/microsoft/callback

# ── Frontend URL (for CORS + OAuth redirects) ────────
FRONTEND_URL=https://your-frontend.onrender.com
# Local dev: http://localhost:5173
